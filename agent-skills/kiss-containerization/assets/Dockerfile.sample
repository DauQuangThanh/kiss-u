# Multi-stage Dockerfile starter. Adapt per project / runtime.

# --- build stage ---
# TODO(kiss-containerization): pin the base image by digest.
FROM node:20-slim AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# --- runtime stage ---
FROM node:20-slim AS runtime
WORKDIR /app
RUN groupadd --gid 10001 app && useradd --uid 10001 --gid app --create-home app
COPY --from=build --chown=app:app /app/dist ./dist
COPY --from=build --chown=app:app /app/node_modules ./node_modules
COPY --from=build --chown=app:app /app/package.json ./package.json

USER app
EXPOSE 8080
HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
    CMD node -e "require('http').get('http://127.0.0.1:8080/health', r => process.exit(r.statusCode===200?0:1))" || exit 1

ENTRYPOINT ["node", "dist/server.js"]
